# Copy to `.env` and fill in values. These keys are required to start the API.

APP_ENV=development

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_commerce
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

JWT_SECRET_KEY=

# Deterministic local embeddings (no external API)
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_DIMENSION=1536

# RAG / chat without external API (local context-based responses)
LLM_PROVIDER=local

# POST /api/v1/orders/{id}/pay - demo only; keep false in production
SIMULATED_PAYMENT_ENABLED=false

# Rate limiting (Redis): rl:{ip}:{route_key}
GLOBAL_RATE_LIMIT_ENABLED=true
GLOBAL_RATE_LIMIT_MAX_REQUESTS=120
GLOBAL_RATE_LIMIT_WINDOW_SEC=60

# Idempotency (checkout and POST .../pay)
IDEMPOTENCY_TTL_SEC=86400

# HTTP tracing (JSON logs with request_id, duration, etc.)
# No extra variables: middleware always active.

# Email (forgot-password); console = logs only
EMAIL_BACKEND=console
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM_ADDRESS=noreply@localhost
PASSWORD_RESET_PUBLIC_BASE_URL=http://localhost:5173

# Embeddings: enqueue indexing in RQ instead of synchronous mode (requires worker)
EMBEDDINGS_ASYNC=false
